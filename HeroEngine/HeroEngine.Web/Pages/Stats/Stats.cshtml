@page
@model StatsPageModel
@{
    ViewData["Title"] = "Estadístiques";
}

<h1>Estadístiques del joc</h1>

<!-- Resum general -->
<div class="card" style="margin-bottom:1rem;">
    <h2>Resum</h2>
    <p>Total d'herois: <strong style="color:#c0b0ff;">@Model.TotalHeroes</strong></p>
</div>

<!-- Tasca 6.2: Top N herois -->
<div class="card" style="margin-bottom:1rem;">
    <div style="display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
        <h2 style="margin-bottom:0;">Top @Model.TopN herois per nivell</h2>
        <form method="get" style="display:flex; gap:0.5rem; align-items:center;">
            <label>N:</label>
            <input type="number" name="topN" value="@Model.TopN" min="1" max="20"
                   class="form-control" style="width:70px;" />
            <input type="hidden" name="selectedClass" value="@Model.SelectedClass" />
            <input type="hidden" name="search" value="@Model.SearchTerm" />
            <button type="submit" class="btn btn-secondary" style="padding:4px 12px;">Actualitza</button>
        </form>
    </div>
    <table style="margin-top:0.5rem;">
        <thead><tr><th>#</th><th>Nom</th><th>Classe</th><th>Nivell</th><th>Max HP</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.TopHeroes.Count; i++)
            {
                var h = Model.TopHeroes[i];
                <tr>
                    <td style="color:#ffcc44; font-weight:700;">@(i + 1)</td>
                    <td>@h.Name</td>
                    <td>@h.HeroClass?.Name</td>
                    <td style="color:#c0b0ff; font-weight:600;">@h.Level</td>
                    <td>@h.MaxHp</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Tasca 7.1: Herois per classe -->
<div class="card" style="margin-bottom:1rem;">
    <h2>Herois per classe</h2>
    <table style="margin-top:0.5rem;">
        <thead><tr><th>Classe</th><th>Herois</th><th>Nivell mitjà</th></tr></thead>
        <tbody>
            @foreach (var row in Model.HeroesByClass)
            {
                <tr>
                    <td style="font-weight:600;">@row.ClassName</td>
                    <td>@row.Count</td>
                    <td style="color:#66dd88;">@(((double)row.AvgLevel).ToString("F1"))</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Tasca 7.2: Habilitats per raresa -->
<div class="card" style="margin-bottom:1rem;">
    <h2>Habilitats per raresa</h2>
    @if (!Model.AbilitiesByRarity.Any())
    {
        <p style="color:#7070a0; font-size:0.9rem;">Cap habilitat registrada.</p>
    }
    else
    {
        <table style="margin-top:0.5rem;">
            <thead><tr><th>Raresa</th><th>Total</th></tr></thead>
            <tbody>
                @foreach (var row in Model.AbilitiesByRarity)
                {
                    <tr>
                        <td style="color: @(row.Rarity == "Legendary" ? "#ffcc44" :
                                                                                                    row.Rarity == "Epic" ? "#bb88ff" :
                                                                                                    row.Rarity == "Rare" ? "#44aaff" : "#aaaaaa");">
                            @row.Rarity
                        </td>
                        <td>@row.Count</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Tasques 6.1 + 6.3 + 7.3: Filtre combinat -->
<div class="card" style="margin-bottom:1rem;">
    <h2>Cerca i filtre</h2>
    <form method="get" style="display:flex; gap:0.75rem; flex-wrap:wrap; margin-bottom:1rem;">
        <input type="hidden" name="topN" value="@Model.TopN" />
        <div>
            <label>Classe:</label>
            <select name="selectedClass" class="form-select">
                <option value="">Totes</option>
                <option value="Warrior" selected="@(Model.SelectedClass == "Warrior")">Warrior</option>
                <option value="Mage" selected="@(Model.SelectedClass == "Mage")">Mage</option>
                <option value="Rogue" selected="@(Model.SelectedClass == "Rogue")">Rogue</option>
            </select>
        </div>
        <div>
            <label>Nivell mínim:</label>
            <input type="number" name="minLevel" value="@Model.MinLevel" min="1" max="100"
                   class="form-control" style="width:80px;" />
        </div>
        <div>
            <label>Cerca per nom:</label>
            <input type="text" name="search" value="@Model.SearchTerm" class="form-control" style="width:180px;" />
        </div>
        <div style="align-self:flex-end;">
            <button type="submit" class="btn btn-primary">Cerca</button>
        </div>
    </form>

    @if (Model.FilteredHeroes.Any())
    {
        <table>
            <thead><tr><th>Nom</th><th>Classe</th><th>Nivell</th></tr></thead>
            <tbody>
                @foreach (var h in Model.FilteredHeroes)
                {
                    <tr>
                        <td><a asp-page="/Heroes/Detail" asp-route-id="@h.Id" style="color:#c0b0ff;">@h.Name</a></td>
                        <td>@h.HeroClass?.Name</td>
                        <td>@h.Level</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (!string.IsNullOrEmpty(Model.SelectedClass) || Model.MinLevel.HasValue)
    {
        <p style="color:#7070a0;">Cap resultat amb els filtres aplicats.</p>
    }

    @if (Model.SearchResults.Any())
    {
        <h3 style="margin-top:1rem;">Resultats de cerca: "@Model.SearchTerm"</h3>
        <table>
            <thead><tr><th>Nom</th><th>Classe</th><th>Nivell</th></tr></thead>
            <tbody>
                @foreach (var h in Model.SearchResults)
                {
                    <tr>
                        <td><a asp-page="/Heroes/Detail" asp-route-id="@h.Id" style="color:#c0b0ff;">@h.Name</a></td>
                        <td>@h.HeroClass?.Name</td>
                        <td>@h.Level</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>