@page
@model CreateModel
@{
    ViewData["Title"] = "Nou heroi";
}

<h1>Nou heroi</h1>

<div class="card" style="max-width:500px;">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div style="margin-bottom:1rem;">
            <label asp-for="Input.Name">Nom</label>
            <input asp-for="Input.Name" class="form-control" />
            <span asp-validation-for="Input.Name" class="text-danger"></span>
        </div>

        <div style="margin-bottom:1rem;">
            <label asp-for="Input.HeroClassId">Classe</label>
            <select asp-for="Input.HeroClassId" asp-items="Model.HeroClassList" class="form-select">
                <option value="">-- Selecciona una classe --</option>
            </select>
            <span asp-validation-for="Input.HeroClassId" class="text-danger"></span>
        </div>

        <div style="margin-bottom:1rem;">
            <label asp-for="Input.Level">Nivell</label>
            <input asp-for="Input.Level" type="number" class="form-control" />
            <span asp-validation-for="Input.Level" class="text-danger"></span>
        </div>

        <div style="margin-bottom:1rem;">
            <label asp-for="Input.Armor">Armadura</label>
            <input asp-for="Input.Armor" type="number" class="form-control" />
            <span asp-validation-for="Input.Armor" class="text-danger"></span>
        </div>

        <div style="margin-bottom:1.5rem;">
            <label asp-for="Input.Biography">Biografia (opcional)</label>
            <textarea asp-for="Input.Biography" class="form-control" rows="3"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Crear heroi</button>
        <a asp-page="/Heroes/Heroes" class="btn btn-secondary" style="margin-left:8px;">Cancel·lar</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}