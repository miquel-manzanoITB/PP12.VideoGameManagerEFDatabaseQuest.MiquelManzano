@page
@model HeroesModel
@{
    ViewData["Title"] = "Heroes";
}

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
    <h1 style="margin-bottom:0;">Heroes of Bytecroft</h1>
    <a asp-page="/Heroes/Create" class="btn btn-primary">+ New hero</a>
</div>

@if (!Model.Heroes.Any())
{
    <div class="card" style="text-align:center; padding:3rem;">
        <p style="color:#7070a0; margin-bottom:1rem;">Encara no hi ha herois registrats.</p>
        <a asp-page="/Heroes/Create" class="btn btn-primary">Crea el primer heroi</a>
    </div>
}
else
{
    <div class="card" style="padding:0; overflow:hidden;">
        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Classe</th>
                    <th>Nivell</th>
                    <th>Max HP</th>
                    <th>Armadura</th>
                    <th>Accions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model.Heroes)
                {
                    <tr>
                        <td>
                            <a asp-page="/Heroes/Detail" asp-route-id="@h.Id"
                                   style="color:#c0b0ff; text-decoration:none; font-weight:500;">
                                @h.Name
                            </a>
                        </td>
                        <td><span class="badge badge-@h.HeroClass?.Name.ToLower()">@h.HeroClass?.Name</span></td>
                        <td>@h.Level</td>
                        <td>@h.MaxHp</td>
                        <td>@(h.Armor > 0 ? h.Armor.ToString() : "—")</td>
                        <td>
                            <a asp-page="/Heroes/Detail" asp-route-id="@h.Id"
                                   class="btn btn-secondary" style="padding:4px 10px; font-size:0.8rem;">
                                Detall
                            </a>
                            <a asp-page="/Heroes/Edit" asp-route-id="@h.Id"
                                   class="btn btn-secondary" style="padding:4px 10px; font-size:0.8rem;">
                                Edita
                            </a>
                            <a asp-page="/Heroes/Delete" asp-route-id="@h.Id"
                                   class="btn btn-danger" style="padding:4px 10px; font-size:0.8rem;">
                                Elimina
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}