@page
@model HeroClassesModel
@{
    ViewData["Title"] = "Classes d'heroi";
}

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
    <h1 style="margin-bottom:0;">Classes d'heroi</h1>
</div>

@if (!ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}

<div class="card" style="padding:0; overflow:hidden;">
    <table>
        <thead>
            <tr>
                <th>Classe</th>
                <th>Descripció</th>
                <th>Herois</th>
                <th>Accions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var hc in Model.HeroClasses)
            {
                <tr>
                    <td style="font-weight:600;">@hc.Name</td>
                    <td style="color:#9090b0;">@hc.Description</td>
                    <td>
                        <a asp-page="/HeroClasses/Details" asp-route-id="@hc.Id"
                               style="color:#c0b0ff;">
                            @hc.Heroes.Count heroi(s)
                        </a>
                    </td>
                    <td>
                        <form method="post" asp-page-handler="Delete" style="display:inline;"
                              onsubmit="return confirm('Eliminar la classe @hc.Name?');">
                            <input type="hidden" name="id" value="@hc.Id" />
                            <button type="submit" class="btn btn-danger"
                                    style="padding:4px 10px; font-size:0.8rem;">
                                Elimina
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>